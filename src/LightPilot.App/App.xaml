<Application x:Class="LightPilot.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#F6F7F8" />
        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="BorderBrushMuted" Color="#D8DDE3" />
        <SolidColorBrush x:Key="TextBrush" Color="#17202A" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#5E6A75" />
        <SolidColorBrush x:Key="AccentBrush" Color="#1D6F8F" />
        <SolidColorBrush x:Key="WarmAccentBrush" Color="#F7BE61" />
        <LinearGradientBrush x:Key="BrandGradientBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#135C73" Offset="0" />
            <GradientStop Color="#1D6F8F" Offset="0.48" />
            <GradientStop Color="#F7BE61" Offset="1" />
        </LinearGradientBrush>

        <Style TargetType="Window">
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="{StaticResource WindowBackgroundBrush}" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="14,6" />
        </Style>

        <Style x:Key="QuietButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#EEF4F6" />
            <Setter Property="BorderBrush" Value="#C8DCE4" />
            <Setter Property="Foreground" Value="#123F50" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="7,4" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="0,4" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="ProgressBar">
            <Setter Property="Height" Value="6" />
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
            <Setter Property="Background" Value="#E7EBEF" />
        </Style>
    </Application.Resources>
</Application>
