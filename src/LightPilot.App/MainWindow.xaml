<Window x:Class="LightPilot.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Light Pilot"
        Icon="Assets/LightPilot.ico"
        Width="420"
        MinWidth="390"
        Height="520"
        MinHeight="490"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="True">
            <Border DockPanel.Dock="Left"
                    Width="52"
                    Height="52"
                    CornerRadius="16"
                    Background="{StaticResource BrandGradientBrush}">
                <Image Source="Assets/LightPilotLogo.png"
                       Width="40"
                       Height="40"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center" />
            </Border>
            <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                <TextBlock Text="Light Pilot" FontSize="23" FontWeight="SemiBold" />
                <TextBlock Text="Automatic screen comfort" Foreground="{StaticResource MutedTextBrush}" />
            </StackPanel>
        </DockPanel>

        <Border Grid.Row="1"
                Margin="0,18,0,0"
                Padding="18"
                Background="{StaticResource PanelBackgroundBrush}"
                BorderBrush="{StaticResource BorderBrushMuted}"
                BorderThickness="1"
                CornerRadius="8">
            <StackPanel>
                <DockPanel>
                    <Border DockPanel.Dock="Right"
                            Background="#E8F2F5"
                            BorderBrush="#B9D9E5"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="10,5"
                            VerticalAlignment="Top">
                        <TextBlock Text="{Binding AutoStatus}"
                                   Foreground="#0D5168"
                                   FontWeight="SemiBold" />
                    </Border>
                    <StackPanel>
                        <TextBlock Text="{Binding CurrentModeText}"
                                   FontSize="27"
                                   FontWeight="SemiBold" />
                        <TextBlock Margin="0,5,22,0"
                                   Text="{Binding Reason}"
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource MutedTextBrush}" />
                    </StackPanel>
                </DockPanel>

                <UniformGrid Columns="3" Margin="0,18,0,0">
                    <StackPanel>
                        <TextBlock Text="Light" Foreground="{StaticResource MutedTextBrush}" />
                        <TextBlock Text="{Binding BrightnessText}" FontSize="18" FontWeight="SemiBold" />
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Warmth" Foreground="{StaticResource MutedTextBrush}" />
                        <TextBlock Text="{Binding WarmthText}" FontSize="18" FontWeight="SemiBold" />
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Flow" Foreground="{StaticResource MutedTextBrush}" />
                        <TextBlock Text="{Binding TransitionText}" FontSize="18" FontWeight="SemiBold" TextWrapping="Wrap" />
                    </StackPanel>
                </UniformGrid>

                <StackPanel Margin="0,20,0,0">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Left"
                                   Text="Comfort"
                                   Foreground="{StaticResource MutedTextBrush}" />
                        <TextBlock DockPanel.Dock="Right"
                                   Text="{Binding ComfortIntensityText}"
                                   FontWeight="SemiBold" />
                    </DockPanel>
                    <Slider Minimum="0"
                            Maximum="100"
                            TickFrequency="5"
                            IsSnapToTickEnabled="True"
                            AutomationProperties.Name="Comfort"
                            Value="{Binding ComfortIntensity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <UniformGrid Columns="3" Margin="0,9,0,0">
                        <Button Content="Light"
                                Margin="0,0,6,0"
                                Style="{StaticResource QuietButton}"
                                Command="{Binding SetCalmCommand}" />
                        <Button Content="Balanced"
                                Margin="3,0,3,0"
                                Style="{StaticResource QuietButton}"
                                Command="{Binding SetBalancedCommand}" />
                        <Button Content="Deep"
                                Margin="6,0,0,0"
                                Style="{StaticResource QuietButton}"
                                Command="{Binding SetDeepComfortCommand}" />
                    </UniformGrid>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="2"
                Margin="0,14,0,0"
                Padding="14"
                Background="{StaticResource PanelBackgroundBrush}"
                BorderBrush="{StaticResource BorderBrushMuted}"
                BorderThickness="1"
                CornerRadius="8">
            <StackPanel>
                <TextBlock Text="Displays" FontWeight="SemiBold" />
                <ScrollViewer Margin="0,8,0,0" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Monitors}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,3,0,12">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="8" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Row="0" Grid.Column="0">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding LightLevel}" Foreground="{StaticResource MutedTextBrush}" />
                                    </StackPanel>
                                    <TextBlock Grid.Row="0"
                                               Grid.Column="1"
                                               Text="{Binding Status}"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               VerticalAlignment="Center" />
                                    <ProgressBar Grid.Row="2"
                                                 Grid.ColumnSpan="2"
                                                 Minimum="0"
                                                 Maximum="100"
                                                 Value="{Binding BrightnessPercent}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </StackPanel>
        </Border>

        <Grid Grid.Row="3" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Content="Pause"
                    AutomationProperties.Name="Pause Light Pilot"
                    Command="{Binding PauseCommand}" />
            <Button Grid.Column="2"
                    Content="Resume"
                    AutomationProperties.Name="Resume automatic comfort"
                    Command="{Binding ResumeCommand}" />
            <Button Grid.Column="4"
                    Content="Settings"
                    AutomationProperties.Name="Open settings"
                    Command="{Binding OpenSettingsCommand}" />
        </Grid>
    </Grid>
</Window>
