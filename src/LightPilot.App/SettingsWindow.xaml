<Window x:Class="LightPilot.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Light Pilot Settings"
        Icon="Assets/LightPilot.ico"
        Width="430"
        Height="640"
        MinWidth="410"
        MinHeight="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0">
            <Image DockPanel.Dock="Left" Source="Assets/LightPilotLogo.png" Width="34" Height="34" />
            <StackPanel Margin="10,0,0,0">
                <TextBlock Text="Light Pilot Settings" FontSize="20" FontWeight="SemiBold" />
                <TextBlock Text="Keep it calm, local, and automatic" Foreground="{StaticResource MutedTextBrush}" />
            </StackPanel>
        </DockPanel>

        <ScrollViewer Grid.Row="1" Margin="0,14,0,16" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Padding="14"
                        Background="{StaticResource PanelBackgroundBrush}"
                        BorderBrush="{StaticResource BorderBrushMuted}"
                        BorderThickness="1"
                        CornerRadius="6">
                    <StackPanel>
                        <CheckBox Content="Start with Windows in the tray"
                                  AutomationProperties.Name="Start with Windows in the tray"
                                  IsChecked="{Binding StartWithWindows, Mode=TwoWay}" />

                        <TextBlock Margin="0,14,0,4"
                                   Text="Comfort intensity"
                                   Foreground="{StaticResource MutedTextBrush}" />
                        <DockPanel>
                            <Slider DockPanel.Dock="Left"
                                    Width="300"
                                    Minimum="0"
                                    Maximum="100"
                                    TickFrequency="5"
                                    IsSnapToTickEnabled="True"
                                    Value="{Binding ComfortIntensity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock DockPanel.Dock="Right"
                                       Text="{Binding ComfortIntensity, StringFormat={}{0}%}"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                        </DockPanel>

                        <Grid Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Wake" Foreground="{StaticResource MutedTextBrush}" />
                                <TextBox Text="{Binding WakeTime, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Sleep" Foreground="{StaticResource MutedTextBrush}" />
                                <TextBox Text="{Binding SleepTime, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Margin="0,12,0,0"
                        Padding="14"
                        Background="{StaticResource PanelBackgroundBrush}"
                        BorderBrush="{StaticResource BorderBrushMuted}"
                        BorderThickness="1"
                        CornerRadius="6">
                    <StackPanel>
                        <TextBlock Text="Brightness range" FontWeight="SemiBold" />
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Minimum" Foreground="{StaticResource MutedTextBrush}" />
                                <Slider Minimum="15"
                                        Maximum="100"
                                        TickFrequency="5"
                                        IsSnapToTickEnabled="True"
                                        AutomationProperties.Name="Minimum brightness"
                                        Value="{Binding MinimumBrightnessPercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="{Binding MinimumBrightnessPercent, StringFormat={}{0}%}" FontWeight="SemiBold" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Maximum" Foreground="{StaticResource MutedTextBrush}" />
                                <Slider Minimum="15"
                                        Maximum="100"
                                        TickFrequency="5"
                                        IsSnapToTickEnabled="True"
                                        AutomationProperties.Name="Maximum brightness"
                                        Value="{Binding MaximumBrightnessPercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="{Binding MaximumBrightnessPercent, StringFormat={}{0}%}" FontWeight="SemiBold" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Margin="0,12,0,0"
                        Padding="14"
                        Background="{StaticResource PanelBackgroundBrush}"
                        BorderBrush="{StaticResource BorderBrushMuted}"
                        BorderThickness="1"
                        CornerRadius="6">
                    <StackPanel>
                        <TextBlock Text="Protection and control" FontWeight="SemiBold" />
                        <CheckBox Margin="0,10,0,0"
                                  Content="Use physical brightness when available"
                                  AutomationProperties.Name="Use physical brightness when available"
                                  IsChecked="{Binding EnableDdcCi, Mode=TwoWay}" />
                        <CheckBox Content="Analyze screen brightness locally"
                                  AutomationProperties.Name="Analyze screen brightness locally"
                                  IsChecked="{Binding EnableContentBrightnessAnalysis, Mode=TwoWay}" />
                        <CheckBox Content="Protect games and videos"
                                  AutomationProperties.Name="Protect games and videos"
                                  IsChecked="{Binding GamingVideoProtection, Mode=TwoWay}" />
                    </StackPanel>
                </Border>

                <Border Margin="0,12,0,0"
                        Padding="14"
                        Background="{StaticResource PanelBackgroundBrush}"
                        BorderBrush="{StaticResource BorderBrushMuted}"
                        BorderThickness="1"
                        CornerRadius="6">
                    <StackPanel>
                        <TextBlock Text="Transition speed" FontWeight="SemiBold" />
                        <DockPanel Margin="0,10,0,0">
                            <Slider DockPanel.Dock="Left"
                                    Width="300"
                                    Minimum="5"
                                    Maximum="180"
                                    TickFrequency="5"
                                    IsSnapToTickEnabled="True"
                                    Value="{Binding TransitionSpeedSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock DockPanel.Dock="Right"
                                       Text="{Binding TransitionSpeedSeconds, StringFormat={}{0}s}"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                        </DockPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <DockPanel Grid.Row="2" LastChildFill="False">
            <Button DockPanel.Dock="Left"
                    Content="Reset"
                    Command="{Binding ResetCommand}" />
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Content="Cancel" Width="86" Click="Cancel_Click" />
                <Button Content="Save" Width="86" Margin="8,0,0,0" Click="Save_Click" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
